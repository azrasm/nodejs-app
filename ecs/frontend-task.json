{
  "containerDefinitions": [
    {
      "command": [],
      "cpu": 256,
      "entryPoint": [],
      "environment": [
        {
          "name": "DB_NAME",
          "value": "DBWT24"
        },
        {
          "name": "DB_USER",
          "value": "${DB_USER}"
        },
        {
          "name": "DB_PASSWORD",
          "value": "${DB_PASSWORD}"
        },
        {
          "name": "DB_HOST",
          "value": "${DB_HOST}"
        },
        {
          "name": "DB_PORT",
          "value": "${DB_PORT}"
        }
      ],
      "essential": true,
      "image": "${REPOSITORY_URL}",
      "memory": 512,
      "mountPoints": [],
      "name": "nodejs-app",
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ],
      "volumesFrom": []
    }
  ],
  "executionRoleArn": "${CI_AWS_TASK_EXECUTION_ROLE}",
  "family": "frontend-task",
  "requiresCompatibilities": [
    "EC2"
  ],
  "taskRoleArn": "${CI_AWS_TASK_EXECUTION_ROLE}",
  "placementConstraints": [
    {
      "expression": "attribute:ecs.subnet-id in [${PUBLIC_SUBNET_ID}]",
      "type": "memberOf"
    }
  ],
  "tags": [
    {
      "key": "Name",
      "value": "arm_ecs_task_definition_frontend"
    }
  ]
}
